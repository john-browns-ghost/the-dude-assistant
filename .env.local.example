# ── Claude (Anthropic) ───────────────────────────────────────────────────────
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ── Spotify ──────────────────────────────────────────────────────────────────
# 1. Go to https://developer.spotify.com/dashboard and create an app
# 2. Add this redirect URI in the app settings:
#      http://localhost:3000/api/spotify/callback
# 3. Paste your Client ID and Client Secret below
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/spotify/callback

# ── OpenAI TTS ───────────────────────────────────────────────────────────────
# Get your key at: https://platform.openai.com/api-keys
# Uses the "onyx" voice (deep, smooth) at speed 0.9 for The Dude's laid-back vibe.
# Cost: ~$0.015 per 1,000 characters (tts-1 model). Very cheap for personal use.
OPENAI_API_KEY=sk-...

# ── Brave Search (optional but recommended) ──────────────────────────────────
# Free tier at: https://brave.com/search/api/  (2000 queries/month free)
# Leave blank to disable web search
BRAVE_SEARCH_API_KEY=
